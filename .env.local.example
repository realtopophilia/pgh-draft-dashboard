# Copy this file to .env.local and fill in your values.
# Never commit .env.local — it's in .gitignore.

# FREE Protomaps API key — get one in 30 seconds at https://protomaps.com/dashboard
# Without this, the map uses OpenStreetMap raster tiles (fine for dev, slow on mobile)
NEXT_PUBLIC_PROTOMAPS_KEY=

# 511PA developer key (for PennDOT traffic speeds, incidents, cameras)
# Apply at https://511pa.com/developers
PENNYDOT_511_KEY=
